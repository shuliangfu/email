{
  "name": "@dreamer/email",
  "version": "1.1.0",
  "description": "Email sending utilities for Deno/Bun/Node.",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts"
  },
  "scripts": {
    "test": "bun test tests/",
    "test:node": "tsx --tsconfig tsconfig.json --test --test-force-exit tests/*.test.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/"
  },
  "dependencies": {
    "@dreamer/i18n": "npm:@jsr/dreamer__i18n@^1.1.2",
    "@dreamer/runtime-adapter": "npm:@jsr/dreamer__runtime-adapter@^1.2.2",
    "@dreamer/service": "npm:@jsr/dreamer__service@^1.1.0"
  },
  "devDependencies": {
    "@dreamer/test": "npm:@jsr/dreamer__test@^1.2.3",
    "tsx": "^4.23.1"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "keywords": ["email", "dreamer"]
}
