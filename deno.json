{
  "name": "@dreamer/email",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "minimumDependencyAge": 0,
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.1.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.2.2",
    "@dreamer/service": "jsr:@dreamer/service@^1.1.0",
    "@dreamer/test": "jsr:@dreamer/test@^1.2.3"
  },
  "allowScripts": {
    "allow": [],
    "deny": [
      "npm:esbuild@0.27.2",
      "npm:puppeteer@24.36.0"
    ]
  }
}
